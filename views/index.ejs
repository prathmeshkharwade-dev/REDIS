<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <section class="p-4">
        <% const users = ["John", "Jane", "Doe"] %>
        <% users.forEach(user => { %>
        <p class="mb-2"><%= user %></p>
        <% }) %>
    </section>
</body>
</html>